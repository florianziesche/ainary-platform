{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3Access",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::ainary-shared-*",
        "arn:aws:s3:::ainary-shared-*/*",
        "arn:aws:s3:::ainary-mia-*",
        "arn:aws:s3:::ainary-mia-*/*"
      ]
    },
    {
      "Sid": "DynamoDB",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "arn:aws:dynamodb:*:350655711792:table/ainary-*"
    },
    {
      "Sid": "SES",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail",
        "ses:GetIdentityVerificationAttributes",
        "ses:VerifyDomainIdentity",
        "ses:VerifyDomainDkim",
        "ses:GetIdentityDkimAttributes",
        "ses:ListIdentities"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Polly",
      "Effect": "Allow",
      "Action": "polly:*",
      "Resource": "*"
    },
    {
      "Sid": "Bedrock",
      "Effect": "Allow",
      "Action": "bedrock:*",
      "Resource": "*"
    },
    {
      "Sid": "Transcribe",
      "Effect": "Allow",
      "Action": "transcribe:*",
      "Resource": "*"
    }
  ]
}
