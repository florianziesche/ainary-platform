{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source",
  "description": "A source of information used in claims",
  "type": "object",
  "required": ["id", "label", "type", "admiralty"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SRC-[0-9]{3}$",
      "description": "Unique source identifier (e.g., SRC-001)"
    },
    "label": {
      "type": "string",
      "description": "Human-readable source name"
    },
    "type": {
      "type": "string",
      "enum": ["primary", "secondary", "derived"],
      "description": "Source classification"
    },
    "admiralty": {
      "type": "string",
      "pattern": "^[A-F][1-6]$",
      "description": "Admiralty Code (A-F for reliability, 1-6 for credibility)"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the source"
    },
    "accessed": {
      "type": "string",
      "format": "date",
      "description": "Date when source was accessed"
    },
    "description": {
      "type": "string",
      "description": "Additional context about the source"
    }
  }
}
