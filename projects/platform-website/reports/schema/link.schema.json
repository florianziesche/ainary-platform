{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Link",
  "description": "A relationship between two claims or entities",
  "type": "object",
  "required": ["from", "to", "type"],
  "properties": {
    "from": {
      "type": "string",
      "description": "Source claim/entity ID"
    },
    "to": {
      "type": "string",
      "description": "Target claim/entity ID"
    },
    "type": {
      "type": "string",
      "enum": ["derived_from", "sourced_by", "about", "contradicts", "supersedes"],
      "description": "Relationship type"
    },
    "reason": {
      "type": "string",
      "description": "Optional explanation for the relationship"
    }
  }
}
