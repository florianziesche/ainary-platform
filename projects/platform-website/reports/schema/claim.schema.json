{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claim",
  "description": "A single claim in the knowledge graph (Evidence, Inference, Judgment, Assumption)",
  "type": "object",
  "required": ["id", "type", "text", "confidence", "section"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-[EIJA]-[0-9]{3}$",
      "description": "Unique claim identifier (e.g., PLTR-E-001)"
    },
    "type": {
      "type": "string",
      "enum": ["E", "I", "J", "A"],
      "description": "E=Evidence, I=Inference, J=Judgment, A=Assumption"
    },
    "text": {
      "type": "string",
      "description": "The claim content"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence level (0-100%)"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Source IDs supporting this claim"
    },
    "derived_from": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Claim IDs this inference/judgment is derived from"
    },
    "invalidated_by": {
      "type": ["string", "null"],
      "description": "Condition under which this claim becomes invalid"
    },
    "valid_until": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date until which this claim is valid"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "Date when claim was created"
    },
    "section": {
      "type": "string",
      "enum": ["financials", "structure", "risk", "valuation", "gaps", "recommendation"],
      "description": "Report section this claim belongs to"
    }
  }
}
