{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Entity",
  "description": "An entity mentioned in the report (company, person, asset)",
  "type": "object",
  "required": ["id", "type", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ENT-[A-Z0-9-]+$",
      "description": "Unique entity identifier (e.g., ENT-PLTR)"
    },
    "type": {
      "type": "string",
      "enum": ["company", "person", "asset"],
      "description": "Entity type"
    },
    "name": {
      "type": "string",
      "description": "Entity name"
    },
    "properties": {
      "type": "object",
      "description": "Additional entity properties (flexible)"
    }
  }
}
